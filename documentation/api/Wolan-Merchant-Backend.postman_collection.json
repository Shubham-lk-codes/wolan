                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessName\": \"Kampala Fresh Foods Ltd\",\n  \"shopName\": \"Kampala Fresh Central\",\n  \"building\": \"Acacia Mall, Shop 14\",\n  \"phone\": \"+256700123456\",\n  \"email\": \"merchant@example.com\",\n  \"ownerName\": \"Amina Nsubuga\",\n  \"address\": \"14 Acacia Avenue, Kampala\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "profile"
              ]
            },
            "description": "Only businessName, shopName, building, phone, email, ownerName, and address are persisted by this endpoint."
          },
          "response": []
        },
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/dashboard",
