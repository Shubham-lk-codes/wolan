{
  "info": {
    "_postman_id": "f7f4de84-f001-4c79-9b63-8c8155de0f01",
    "name": "Wolan Merchant Backend API",
    "description": "All merchant-backend endpoints with Postman-ready dummy data. Before testing, set merchantIdentifier and merchantPassword to a real onboarded merchant account. Login automatically stores accessToken and refreshToken. Create Order automatically stores orderId. List Notifications stores the first notificationId. The development seed creates an admin account only, not a merchant account.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://wolan-merchant.onrender.com/api/v1/merchant",
      "type": "string"
    },
    {
      "key": "merchantIdentifier",
      "value": "merchant@example.com",
      "type": "string"
    },
    {
      "key": "merchantPassword",
      "value": "MerchantPass123!",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "64b64c000000000000000001",
      "type": "string"
    },
    {
      "key": "notificationId",
      "value": "64b64c000000000000000002",
      "type": "string"
    },
    {
      "key": "otpId",
      "value": "64b64c000000000000000003",
      "type": "string"
    },
    {
      "key": "resetCode",
      "value": "123456",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Checks whether the Merchant API and MongoDB connection are available."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body && body.data && body.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{merchantIdentifier}}\",\n  \"password\": \"{{merchantPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Requires a real active user whose role is MERCHANT. A successful response automatically stores both tokens."
          },
          "response": []
        },
        {
          "name": "Refresh Tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body && body.data && body.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Rotates the refresh token and automatically updates the stored tokens."
          },
          "response": []
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{merchantIdentifier}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "forgot"
              ]
            },
            "description": "Creates a password-reset OTP when the account exists. The API intentionally returns the same accepted response for unknown accounts."
          },
          "response": []
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otpId\": \"{{otpId}}\",\n  \"code\": \"{{resetCode}}\",\n  \"password\": \"NewMerchantPass123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "reset"
              ]
            },
            "description": "Dummy values demonstrate the required format only. Supply the real 24-character OTP ID and six-digit code created by Forgot Password."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "Revokes the current refresh-token session. Run this after other authenticated tests."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Profile and Dashboard",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
