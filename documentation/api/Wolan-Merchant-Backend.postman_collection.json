    {
      "name": "Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders?page=1&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "orderStatus",
                  "value": "PENDING",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "WOL",
                  "disabled": true
                },
                {
                  "key": "sortBy",
                  "value": "createdAt",
                  "disabled": true
                },
                {
                  "key": "sortOrder",
                  "value": "desc",
                  "disabled": true
                }
              ]
            },
            "description": "Valid orderStatus values: PENDING, ASSIGNED, ACCEPTED, PICKED_UP, AT_HUB, OUT_FOR_DELIVERY, DELIVERED, FAILED, RETURN_REQUESTED, RETURNED, CANCELLED."
          },
          "response": []
        },
        {
          "name": "Create COD Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body && body.data && body.data._id) {",
                  "  pm.collectionVariables.set('orderId', body.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": {\n    \"name\": \"John Kato\",\n    \"phone\": \"+256701234567\",\n    \"email\": \"john.kato@example.com\"\n  },\n  \"pickup\": {\n    \"name\": \"Kampala Fresh Central\",\n    \"phone\": \"+256700123456\",\n    \"address\": \"14 Acacia Avenue, Kampala\",\n    \"instructions\": \"Ask for Amina at the front desk\",\n    \"location\": {\n      \"longitude\": 32.5825,\n      \"latitude\": 0.3476\n    }\n  },\n  \"delivery\": {\n    \"name\": \"John Kato\",\n    \"phone\": \"+256701234567\",\n    \"address\": \"Plot 22 Kira Road, Kampala\",\n    \"instructions\": \"Call on arrival\",\n    \"location\": {\n      \"longitude\": 32.5968,\n      \"latitude\": 0.3652\n    }\n  },\n  \"itemDescription\": \"One sealed box of fresh groceries\",\n  \"declaredValue\": 150000,\n  \"paymentMethod\": \"COD\",\n  \"codAmount\": 175000,\n  \"insurance\": true,\n  \"serviceType\": \"EXPRESS\",\n  \"distanceKm\": 7.5,\n  \"packageSize\": \"MEDIUM\",\n  \"batchGroup\": \"POSTMAN-DEMO-001\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Creates a COD order and stores its _id in orderId. For PREPAID, set paymentMethod to PREPAID and codAmount to 0. hubId and merchantId are derived from the authenticated merchant."
          },
          "response": []
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "{{orderId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Mark Order Ready for Pickup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}/send-off",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "{{orderId}}",
                "send-off"
              ]
            },
            "description": "Marks the merchant package as ready for pickup. No JSON body is required."
          },
          "response": []
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Customer requested cancellation before pickup\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}/cancel",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "{{orderId}}",
                "cancel"
              ]
            },
            "description": "Cancellation is valid only from an order state that allows transition to CANCELLED."
          },
          "response": []
        },
        {
          "name": "Get Order Tracking",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}/tracking",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "{{orderId}}",
                "tracking"
              ]
            }
          },
          "response": []
        }
      ]
